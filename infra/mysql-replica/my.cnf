# MySQL Replica (Slave) 설정
[mysqld]

# 서버 고유 ID
server-id = 2

# Replica 읽기 전용 설정
# super-read-only 설정은 docker-compose에서
read-only = ON

# Relay 로그 설정
relay-log = relay-bin
log_replica_updates = ON   # Replica의 변경사항도 binlog에 기록 (MySQL 8.4+)

# 복제 대상 DB 지정
replicate-do-db = card_db

# 성능 및 안정성 설정
max_connections = 200
innodb_buffer_pool_size = 256M

# 문자셋
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

gtid-mode = ON
enforce-gtid-consistency = ON
