# MySQL Node2 설정 (Secondary)
[mysqld]

# 서버 고유 ID
server-id = 2

# Group Replication이 Secondary에서 super_read_only를 자동 관리
read-only = ON

# 바이너리 로그 설정 (Group Replication: 모든 노드 필수)
log-bin           = mysql-bin
binlog-format     = ROW
relay-log         = relay-bin
log_replica_updates = ON

# 성능 및 안정성 설정
max_connections        = 200
innodb_buffer_pool_size = 256M

# 문자셋
character-set-server = utf8mb4
collation-server     = utf8mb4_unicode_ci

# GTID
gtid-mode               = ON
enforce-gtid-consistency = ON

# ----------------------------------------------------------
# Group Replication
# replicate-do-db 제거: 클러스터 메타데이터 스키마 복제 필요
# ----------------------------------------------------------
binlog_checksum = NONE

loose-group_replication_group_name            = "8f6e4dc3-9a2b-11ee-b9d1-0242ac120002"
loose-group_replication_start_on_boot         = OFF
loose-group_replication_local_address         = "mysql-node2:33061"
loose-group_replication_group_seeds           = "mysql-node1:33061,mysql-node2:33061,mysql-node3:33061"
